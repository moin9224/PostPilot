# ============================================================================
# OpenAI API Configuration (for content generation)
# ============================================================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_api_key_here

# ============================================================================
# OAuth Providers
# ============================================================================

# Google OAuth - Get from: https://console.cloud.google.com
# 1. Create a GCP project
# 2. Enable Google+ API
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add authorized redirect URIs:
#    - http://localhost:3000/auth/callback
#    - https://thepostpilot.vercel.app/auth/callback
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# LinkedIn OAuth - Get from: https://www.linkedin.com/developers/apps
# 1. Create an app
# 2. Request access to "Sign In with LinkedIn using OpenID Connect"
# 3. Add Authorized redirect URLs:
#    - http://localhost:3000/auth/callback
#    - https://thepostpilot.vercel.app/auth/callback
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
NEXT_PUBLIC_LINKEDIN_REDIRECT_URI=http://localhost:3000/auth/callback

# ============================================================================
# Stripe Configuration (for billing)
# ============================================================================
# Get from: https://dashboard.stripe.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# ============================================================================
# Email Configuration (for notifications)
# ============================================================================
# Get from: https://resend.com
RESEND_API_KEY=re_your_key_here
NEXT_PUBLIC_SUPPORT_EMAIL=support@postpilot.io

# ============================================================================
# Application Configuration
# ============================================================================
