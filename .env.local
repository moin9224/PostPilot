NODE_ENV=development

# ============================================================================
# LinkedIn API Configuration (for scraping and analytics)
# ============================================================================
LINKEDIN_API_BASE_URL=https://api.linkedin.com/rest
LINKEDIN_PROFILE_SYNC_ENABLED=true
